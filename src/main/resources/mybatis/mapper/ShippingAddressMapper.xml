<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zky.dao.ShippingAddressDao">

    <resultMap id="BaseResultMap" type="com.zky.domain.po.ShippingAddress">
        <id column="id" property="id" />
        <result column="user_id" property="userId" />
        <result column="receiver_name" property="receiverName" />
        <result column="receiver_phone" property="receiverPhone" />
        <result column="province" property="province" />
        <result column="city" property="city" />
        <result column="detail_address" property="detailAddress" />
        <result column="is_default" property="isDefault" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
    </resultMap>

    <insert id="insert" parameterType="com.zky.domain.po.ShippingAddress" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO shipping_address (user_id, receiver_name, receiver_phone, province, city, detail_address, is_default, create_time, update_time)
        VALUES (#{userId}, #{receiverName}, #{receiverPhone}, #{province}, #{city}, #{detailAddress}, #{isDefault}, NOW(), NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM shipping_address WHERE id = #{id}
    </delete>

    <update id="update" parameterType="com.zky.domain.po.ShippingAddress">
        UPDATE shipping_address
        <set>
            <if test="receiverName != null">receiver_name = #{receiverName},</if>
            <if test="receiverPhone != null">receiver_phone = #{receiverPhone},</if>
            <if test="province != null">province = #{province},</if>
            <if test="city != null">city = #{city},</if>
            <if test="detailAddress != null">detail_address = #{detailAddress},</if>
            <if test="isDefault != null">is_default = #{isDefault},</if>
            update_time = NOW()
        </set>
        WHERE id = #{id}
    </update>

    <update id="clearDefault">
        UPDATE shipping_address SET is_default = 0 WHERE user_id = #{userId}
    </update>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM shipping_address WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM shipping_address WHERE user_id = #{userId} ORDER BY is_default DESC, create_time DESC
    </select>

</mapper>
