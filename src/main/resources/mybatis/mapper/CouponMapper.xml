<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zky.dao.CouponDao">

    <resultMap id="BaseResultMap" type="com.zky.domain.po.Coupon">
        <id column="id" property="id" />
        <result column="coupon_id" property="couponId" />
        <result column="category" property="category" />
        <result column="coupon_type" property="couponType" />
        <result column="value" property="value" />
        <result column="name" property="name" />
        <result column="status" property="status" />
    </resultMap>

    <select id="selectByCouponId" resultMap="BaseResultMap">
        SELECT *
        FROM coupon
        WHERE coupon_id = #{couponId}
        LIMIT 1
    </select>

    <select id="selectAvailableByCategory" resultMap="BaseResultMap">
        SELECT *
        FROM coupon
        WHERE category = #{category}
          AND status = 1
    </select>

    <select id="selectAvailableByCategories" resultMap="BaseResultMap">
        SELECT *
        FROM coupon
        WHERE category IN
        <foreach collection="categories" item="category" open="(" separator="," close=")">
            #{category}
        </foreach>
          AND status = 1
    </select>

</mapper>

