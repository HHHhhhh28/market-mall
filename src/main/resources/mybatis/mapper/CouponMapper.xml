<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zky.dao.CouponDao">

    <resultMap id="BaseResultMap" type="com.zky.domain.po.Coupon">
        <id column="id" property="id" />
        <result column="coupon_id" property="couponId" />
        <result column="category" property="category" />
        <result column="coupon_type" property="couponType" />
        <result column="value" property="value" />
        <result column="name" property="name" />
        <result column="status" property="status" />
    </resultMap>

    <select id="selectByCouponId" resultMap="BaseResultMap">
        SELECT *
        FROM coupon
        WHERE coupon_id = #{couponId}
        LIMIT 1
    </select>

    <select id="selectAvailableByCategory" resultMap="BaseResultMap">
        SELECT *
        FROM coupon
        WHERE category = #{category}
          AND status = 1
    </select>

    <select id="selectAvailableByCategories" resultMap="BaseResultMap">
        SELECT * FROM coupon
        <where>
            status = 1
            <if test="categories != null and categories.size() > 0">
                AND category IN
                <foreach collection="categories" item="category" open="(" separator="," close=")">
                    #{category}
                </foreach>
            </if>
        </where>
        ORDER BY category, coupon_type
    </select>

    <select id="selectAllForAdmin" resultMap="BaseResultMap">
        SELECT * FROM coupon ORDER BY category, coupon_type
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO coupon (coupon_id, category, coupon_type, value, name, status)
        VALUES (#{couponId}, #{category}, #{couponType}, #{value}, #{name}, #{status})
    </insert>

    <update id="update">
        UPDATE coupon
        SET value = #{value}, status = #{status}
        WHERE coupon_id = #{couponId}
    </update>

    <delete id="deleteByCouponId">
        DELETE FROM coupon WHERE coupon_id = #{couponId}
    </delete>

</mapper>

